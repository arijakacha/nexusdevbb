<div class="np-card">
    <div class="np-card__header">
        <h3 class="np-card__title">🌤️ Weather</h3>
    </div>
    <div class="np-card__body text-center">
        {% if weather %}
            <div class="mb-3">
                {% if weather.icon %}
                    <img src="https://openweathermap.org/img/wn/{{ weather.icon }}@2x.png" alt="{{ weather.description }}">
                {% endif %}
            </div>
            <h4>{{ weather.city|default('Unknown') }}</h4>
            <div class="display-4 mb-2">{{ weather.temperature }}°C</div>
            <p class="text-muted text-capitalize">{{ weather.description }}</p>
            <div class="row mt-3">
                <div class="col-6">
                    <small class="text-muted">Humidity</small>
                    <div>{{ weather.humidity }}%</div>
                </div>
                <div class="col-6">
                    <small class="text-muted">Wind Speed</small>
                    <div>{{ weather.wind_speed }} m/s</div>
                </div>
            </div>
        {% else %}
            <p class="text-muted">Weather data unavailable</p>
        {% endif %}
    </div>
</div>

