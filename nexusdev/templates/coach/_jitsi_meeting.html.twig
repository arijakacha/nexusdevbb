{# Jitsi Meeting Embedded Component - Premium Enhanced Version with Icons #}
<div id="jitsi-meeting-container" style="display: none;">
    <div class="card border-0 shadow-xl" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 20px; overflow: hidden;">
        <!-- Header Section -->
        <div class="card-header bg-transparent border-0 px-4 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-white">
                    <h5 class="mb-1 d-flex align-items-center fw-bold">
                        <div class="bg-white bg-opacity-20 rounded-pill p-2 me-3">
                            <i class="bi bi-camera-video-fill text-white fs-5"></i>
                        </div>
                        Video Meeting
                        <span class="badge bg-white text-purple-600 ms-3 px-3 py-2" id="meeting-status-badge" style="font-weight: 600;">
                            <i class="bi bi-broadcast-fill text-danger me-1" style="font-size: 8px;"></i>LIVE
                        </span>
                    </h5>
                    <p class="mb-0 opacity-90" style="font-size: 0.9rem;">
                        <i class="bi bi-person-circle me-2"></i>
                        with <strong>{{ session.player.nickname }}</strong>
                        <i class="bi bi-calendar-check ms-3 me-1"></i>
                        <span>{{ session.scheduledAt|date('M j, Y') }}</span>
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <button id="toggle-audio" class="btn btn-light btn-sm rounded-circle p-3 shadow-sm" title="Toggle Audio" style="width: 48px; height: 48px;">
                        <i class="bi bi-mic-fill text-dark fs-5"></i>
                    </button>
                    <button id="toggle-video" class="btn btn-light btn-sm rounded-circle p-3 shadow-sm" title="Toggle Video" style="width: 48px; height: 48px;">
                        <i class="bi bi-camera-video-fill text-dark fs-5"></i>
                    </button>
                    <button id="toggle-screen" class="btn btn-light btn-sm rounded-circle p-3 shadow-sm" title="Share Screen" style="width: 48px; height: 48px;">
                        <i class="bi bi-display-fill text-dark fs-5"></i>
                    </button>
                    <button id="toggle-chat" class="btn btn-light btn-sm rounded-circle p-3 shadow-sm" title="Toggle Chat" style="width: 48px; height: 48px;">
                        <i class="bi bi-chat-dots-fill text-dark fs-5"></i>
                    </button>
                    <button id="toggle-record" class="btn btn-light btn-sm rounded-circle p-3 shadow-sm" title="Record Meeting" style="width: 48px; height: 48px;">
                        <i class="bi bi-record-circle text-danger fs-5"></i>
                    </button>
                    <button id="end-meeting" class="btn btn-warning btn-sm rounded-circle p-3 shadow-sm" title="End Video Call" style="width: 48px; height: 48px;">
                        <i class="bi bi-telephone-x-fill text-white fs-5"></i>
                    </button>
                    <button id="end-session" class="btn btn-danger btn-sm rounded-circle p-3 shadow-sm" title="End Meeting & Complete Session" style="width: 48px; height: 48px;">
                        <i class="bi bi-stop-circle-fill text-white fs-5"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Video Container -->
        <div class="px-4 pb-3">
            <div id="jitsi-meeting-frame" class="rounded-4 overflow-hidden shadow-lg" style="height: 500px; background: #000; position: relative;">
                <div id="meeting-loader" class="position-absolute top-50 start-50 translate-middle text-white">
                    <div class="text-center">
                        <div class="spinner-border text-light mb-3" role="status" style="width: 3rem; height: 3rem;">
                            <span class="visually-hidden">Loading meeting...</span>
                        </div>
                        <h6 class="fw-light">
                            <i class="bi bi-wifi me-2"></i>Connecting to meeting room...
                        </h6>
                        <div class="mt-2">
                            <div class="progress" style="height: 4px; width: 200px;">
                                <div class="progress-bar bg-light progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
                            </div>
                        </div>
                        <div class="mt-3">
                            <small class="opacity-75">
                                <i class="bi bi-shield-lock me-1"></i>Secure connection establishing
                            </small>
                        </div>
                    </div>
                </div>
                <!-- Jitsi iframe will be embedded here -->
            </div>
        </div>
        
        <!-- Footer Controls -->
        <div class="card-footer bg-transparent border-0 px-4 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-white" style="font-size: 0.9rem;">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-20 rounded-pill px-3 py-1 me-3">
                            <i class="bi bi-shield-check me-1"></i>
                            <span id="meeting-security">Secure Encrypted</span>
                        </div>
                        <div class="bg-white bg-opacity-20 rounded-pill px-3 py-1 me-3">
                            <i class="bi bi-people-fill me-1"></i>
                            <span id="participant-count">1</span> Participant
                        </div>
                        <div class="bg-white bg-opacity-20 rounded-pill px-3 py-1">
                            <i class="bi bi-clock-fill me-1"></i>
                            Expires: <strong>{{ session.meetingExpiresAt|date('H:i') }}</strong>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button id="copy-meeting-link" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm">
                        <i class="bi bi-clipboard me-1"></i>Copy Link
                    </button>
                    <button id="invite-participant" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm">
                        <i class="bi bi-person-plus me-1"></i>Invite
                    </button>
                    <button id="meeting-settings" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm">
                        <i class="bi bi-gear-fill me-1"></i>Settings
                    </button>
                    <button id="fullscreen-meeting" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm">
                        <i class="bi bi-fullscreen me-1"></i>Fullscreen
                    </button>
                </div>
            </div>
            
            <!-- Meeting Info Bar -->
            <div class="mt-3 p-3 bg-white bg-opacity-10 rounded-3">
                <div class="d-flex justify-content-between align-items-center text-white">
                    <div class="d-flex align-items-center">
                        <div class="me-4">
                            <small class="opacity-75 d-block mb-1">
                                <i class="bi bi-info-circle me-1"></i>Meeting Controls
                            </small>
                            <div class="mt-1">
                                <span class="badge bg-warning text-dark me-2 rounded-pill">
                                    <i class="bi bi-telephone-fill me-1"></i>End Call
                                </span>
                                <span class="badge bg-danger me-2 rounded-pill">
                                    <i class="bi bi-stop-circle-fill me-1"></i>End Session
                                </span>
                                <span class="badge bg-info me-2 rounded-pill">
                                    <i class="bi bi-record-fill me-1"></i>Record
                                </span>
                            </div>
                        </div>
                    </div>
                    <div id="meeting-timer" class="text-center">
                        <div class="bg-white bg-opacity-20 rounded-pill px-4 py-2">
                            <i class="bi bi-stopwatch-fill me-2"></i>
                            <span id="timer-display" class="fw-bold" style="font-family: 'Courier New', monospace;">00:00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="meeting-placeholder" class="card border-0 shadow-lg" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); border-radius: 20px; overflow: hidden;">
    <div class="card-body text-center py-5">
        <!-- Icon Section -->
        <div class="mb-4">
            <div class="bg-white bg-opacity-50 rounded-circle p-4 d-inline-block shadow-sm">
                <i class="bi bi-camera-video-off display-1 text-muted"></i>
            </div>
        </div>
        
        <!-- Title Section -->
        <h4 class="mb-3 fw-bold text-dark">
            <i class="bi bi-camera-video me-2"></i>Video Meeting
        </h4>
        
        <!-- Status Section -->
        <div class="mb-4">
            {% if session.meetingUrl and session.isMeetingActive() %}
                <div class="alert alert-success d-inline-flex align-items-center px-4 rounded-pill shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <i class="bi bi-wifi me-1"></i>
                    <strong>Meeting is ready to start</strong>
                </div>
            {% else %}
                {% if session.meetingUrl %}
                    <div class="alert alert-warning d-inline-flex align-items-center px-4 rounded-pill shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <i class="bi bi-clock-history me-1"></i>
                        <strong>Meeting has expired</strong>
                    </div>
                {% else %}
                    <div class="alert alert-info d-inline-flex align-items-center px-4 rounded-pill shadow-sm" role="alert">
                        <i class="bi bi-plus-circle me-2"></i>
                        <i class="bi bi-calendar-plus me-1"></i>
                        <strong>No meeting created yet</strong>
                    </div>
                {% endif %}
            {% endif %}
        </div>
        
        <!-- Session Info -->
        <div class="mb-4 text-muted">
            <div class="d-flex justify-content-center align-items-center gap-3">
                <span>
                    <i class="bi bi-calendar3 me-1"></i>
                    {{ session.scheduledAt|date('M j, Y') }}
                </span>
                <span>
                    <i class="bi bi-clock me-1"></i>
                    {{ session.scheduledAt|date('H:i') }}
                </span>
                <span>
                    <i class="bi bi-person me-1"></i>
                    {{ session.player.nickname }}
                </span>
            </div>
        </div>
        
        <!-- Action Button -->
        {% if session.meetingUrl and session.isMeetingActive() %}
            <button id="start-meeting-btn" class="btn btn-success btn-lg rounded-pill px-5 shadow-lg mb-4" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); border: none;">
                <i class="bi bi-play-circle-fill me-2"></i>Start Meeting
            </button>
            
            {# Premium WhatsApp Status Section #}
            <div id="sms-status" class="mt-4">
                {% if session.player.phoneNumber %}
                    <div class="card border-0 shadow-sm mb-3" style="background: linear-gradient(135deg, #25d366 0%, #128c7e 100%); border-radius: 15px;">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-white bg-opacity-20 rounded-circle p-3 me-3">
                                    <i class="bi bi-whatsapp text-white fs-4"></i>
                                </div>
                                <div class="text-start">
                                    <h6 class="mb-1 fw-bold text-white">
                                        <i class="bi bi-check2-square me-1"></i>WhatsApp Ready
                                    </h6>
                                    <small class="text-white opacity-90">
                                        <i class="bi bi-chat-dots me-1"></i>
                                        Meeting link ready for {{ session.player.phoneNumber }}
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="card border-0 shadow-sm mb-3" style="background: linear-gradient(135deg, #ffeaa7 0%, #fdcb6e 100%); border-radius: 15px;">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-white bg-opacity-50 rounded-circle p-3 me-3">
                                    <i class="bi bi-exclamation-triangle-fill text-warning fs-4"></i>
                                </div>
                                <div class="text-start">
                                    <h6 class="mb-1 fw-bold text-dark">
                                        <i class="bi bi-x-square me-1"></i>WhatsApp Unavailable
                                    </h6>
                                    <small class="text-dark">
                                        <i class="bi bi-phone-x me-1"></i>
                                        Player has no phone number on file
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
                
                {# Premium Manual WhatsApp Testing Section #}
                <div class="card border-0 shadow-lg" style="background: linear-gradient(135deg, #25d366 0%, #128c7e 100%); border-radius: 15px;">
                    <div class="card-body p-4">
                        <h6 class="mb-4 d-flex align-items-center fw-bold text-white">
                            <div class="bg-white bg-opacity-20 rounded-circle p-2 me-3">
                                <i class="bi bi-whatsapp text-white fs-4"></i>
                            </div>
                            <i class="bi bi-send-check me-2"></i>Send via WhatsApp
                        </h6>
                        <div class="row g-3">
                            <div class="col-md-8">
                                <div class="input-group input-group-lg shadow-sm">
                                    <span class="input-group-text bg-white border-0 rounded-start-pill">
                                        <i class="bi bi-telephone-fill text-success"></i>
                                    </span>
                                    <input type="tel" id="manual-phone" class="form-control border-0 rounded-end-pill text-dark" 
                                           placeholder="+1234567890" 
                                           value="{{ session.player.phoneNumber|default('') }}"
                                           style="background: rgba(255,255,255,0.9); color: #000 !important;">
                                </div>
                                <div class="d-flex justify-content-between mt-2">
                                    <small class="text-white opacity-90">
                                        <i class="bi bi-info-circle me-1"></i>
                                        Include country code: +1 (US), +44 (UK)
                                    </small>
                                    <small class="text-white opacity-90">
                                        <i class="bi bi-shield-check me-1"></i>
                                        Instant Delivery
                                    </small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <button id="send-test-whatsapp" class="btn btn-light btn-lg w-100 rounded-pill h-100 shadow-lg" style="background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%); border: none; color: #25d366;">
                                    <i class="bi bi-whatsapp me-2"></i>Send WhatsApp
                                </button>
                            </div>
                        </div>
                        
                        <!-- WhatsApp Features -->
                        <div class="mt-3 text-center">
                            <small class="text-white opacity-90">
                                <span class="me-3"><i class="bi bi-check-circle me-1"></i>Instant Message</span>
                                <span class="me-3"><i class="bi bi-globe me-1"></i>Global Reach</span>
                                <span><i class="bi bi-chat-dots me-1"></i>Chat Format</span>
                            </small>
                        </div>
                        
                        <!-- Test Button -->
                        <div class="mt-3 text-center">
                            <button onclick="testWhatsAppNow()" class="btn btn-sm btn-outline-light">
                                <i class="bi bi-play-circle me-1"></i>Test WhatsApp
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <button id="create-meeting-btn" class="btn btn-primary btn-lg rounded-pill px-5 shadow-lg" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">
                <i class="bi bi-plus-circle-fill me-2"></i>Create Meeting
            </button>
            
            <!-- Meeting Features -->
            <div class="mt-4 text-muted">
                <div class="d-flex justify-content-center align-items-center gap-4">
                    <span>
                        <i class="bi bi-hdmi-fill text-primary me-1"></i>HD Video
                    </span>
                    <span>
                        <i class="bi bi-mic-fill text-success me-1"></i>Clear Audio
                    </span>
                    <span>
                        <i class="bi bi-shield-fill text-warning me-1"></i>Secure
                    </span>
                    <span>
                        <i class="bi bi-people-fill text-info me-1"></i>Group Chat
                    </span>
                </div>
            </div>
        {% endif %}
    </div>
</div>

<style>
/* Premium Enhanced Styles */
.shadow-xl {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
}

#jitsi-meeting-frame iframe {
    width: 100%;
    height: 100%;
    border: none;
}

/* Enhanced button animations */
.btn {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: none !important;
}

.btn:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
}

.btn:active {
    transform: translateY(0) scale(0.98);
}

/* Circular button enhancements */
.btn.rounded-circle {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn.rounded-circle:hover {
    transform: translateY(-2px) rotate(10deg) scale(1.1);
}

/* Meeting status badge animation */
@keyframes pulse-glow {
    0% { 
        box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
        transform: scale(1);
    }
    50% { 
        box-shadow: 0 0 0 10px rgba(255, 255, 255, 0);
        transform: scale(1.05);
    }
    100% { 
        box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
        transform: scale(1);
    }
}

#meeting-status-badge {
    animation: pulse-glow 2s infinite;
}

/* Enhanced loading spinner */
.spinner-border {
    border-width: 3px;
}

/* Card hover effects */
.card {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card:hover {
    transform: translateY(-5px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.15) !important;
}

/* Input group enhancements */
.input-group-text {
    background: rgba(255,255,255,0.9);
    border: none;
    transition: all 0.3s ease;
}

.form-control:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
    background: rgba(255,255,255,0.95) !important;
}

/* Alert enhancements */
.alert {
    border: none;
    border-radius: 50px;
    font-weight: 500;
}

/* Progress bar enhancements */
.progress {
    background-color: rgba(255,255,255,0.3);
    border-radius: 10px;
}

.progress-bar {
    border-radius: 10px;
}

/* Timer styling */
#meeting-timer {
    font-family: 'Courier New', monospace;
    font-weight: 700;
    letter-spacing: 1px;
}

/* Micro-interactions */
.btn:focus {
    outline: none;
    box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
}

/* Enhanced transitions */
* {
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
}

/* Glass morphism effect */
.glass-effect {
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.18);
}
</style>

<script>
let jitsiApi = null;
let meetingActive = false;
let meetingStartTime = null;
let timerInterval = null;

function initializeJitsi(meetingUrl) {
    const domain = "8x8.vc";
    const options = {
        roomName: "{{ session.meetingRoom|default('') }}",
        width: "100%",
        height: "100%",
        parentNode: document.querySelector("#jitsi-meeting-frame"),
        jwt: meetingUrl.includes('jwt=') ? new URL(meetingUrl).searchParams.get('jwt') : null,
        configOverwrite: {
            prejoinPageEnabled: false,
            startWithAudioMuted: false,
            startWithVideoMuted: false,
            subject: "Coaching Session with {{ session.player.nickname }}",
            hideConferenceSubject: false,
            hideParticipantsStats: false,
            hideRecordingButton: true,
            hideRaiseHandButton: false,
            enableFeaturesBasedOnToken: true,
            brandingRoomAlias: "{{ session.meetingRoom|default('') }}",
        },
        interfaceConfigOverwrite: {
            TOOLBAR_BUTTONS: [
                'microphone', 'camera', 'closedcaptions', 'desktop', 'fullscreen',
                'fodeviceselection', 'hangup', 'profile', 'info', 'chat',
                'recording', 'livestreaming', 'etherpad', 'sharedvideo', 'settings',
                'raisehand', 'videoquality', 'filmstrip', 'videobackgroundblur', 'download',
                'help', 'mute-everyone', 'e2ee'
            ],
            SETTINGS_SECTIONS: ['devices', 'language', 'profile', 'moderator'],
            SHOW_CHROME_EXTENSION_BANNER: false,
        },
        userInfo: {
            displayName: "{{ app.user.coach.user.username|default('Coach') }}",
            email: "{{ app.user.email|default('coach@nexusplay.test') }}"
        }
    };

    // Hide loader when Jitsi loads
    document.getElementById('meeting-loader').style.display = 'none';

    // Load Jitsi API
    const script = document.createElement('script');
    script.src = 'https://8x8.vc/external_api.js';
    script.async = true;
    script.onload = function() {
        if (typeof JitsiMeetExternalAPI !== 'undefined') {
            jitsiApi = new JitsiMeetExternalAPI(domain, options);
            
            jitsiApi.addEventListener('videoConferenceJoined', function() {
                console.log('Meeting joined successfully');
                meetingActive = true;
                meetingStartTime = new Date();
                startMeetingTimer();
                updateMeetingControls();
                updateMeetingStatus('LIVE', 'success');
            });
            
            jitsiApi.addEventListener('participantJoined', function() {
                console.log('Participant joined');
                showNotification('Participant joined the meeting', 'info');
            });
            
            jitsiApi.addEventListener('participantLeft', function() {
                console.log('Participant left');
            });
            
            jitsiApi.addEventListener('readyToClose', function() {
                console.log('Meeting ready to close');
                endMeeting();
            });
            
            // Setup control buttons
            setupMeetingControls();
        }
    };
    document.head.appendChild(script);
}

function startMeetingTimer() {
    timerInterval = setInterval(function() {
        if (meetingActive && meetingStartTime) {
            const now = new Date();
            const elapsed = Math.floor((now - meetingStartTime) / 1000);
            const minutes = Math.floor(elapsed / 60);
            const seconds = elapsed % 60;
            document.getElementById('timer-display').textContent = 
                `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }
    }, 1000);
}

function stopMeetingTimer() {
    if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
    }
    document.getElementById('timer-display').textContent = '00:00';
}

function updateMeetingStatus(status, type) {
    const badge = document.getElementById('meeting-status-badge');
    if (badge) {
        badge.textContent = status;
        badge.className = `badge bg-${type} ms-2`;
    }
}

function setupMeetingControls() {
    // Audio toggle with enhanced feedback
    document.getElementById('toggle-audio').addEventListener('click', function() {
        if (jitsiApi) {
            jitsiApi.isAudioMuted().then(muted => {
                if (muted) {
                    jitsiApi.unmuteAudio();
                    this.classList.remove('btn-danger');
                    this.classList.add('btn-outline-secondary');
                    this.innerHTML = '<i class="bi bi-mic-fill"></i>';
                    showNotification('Microphone unmuted', 'success');
                } else {
                    jitsiApi.muteAudio();
                    this.classList.remove('btn-outline-secondary');
                    this.classList.add('btn-danger');
                    this.innerHTML = '<i class="bi bi-mic-mute-fill"></i>';
                    showNotification('Microphone muted', 'info');
                }
            });
        }
    });
    
    // Video toggle with enhanced feedback
    document.getElementById('toggle-video').addEventListener('click', function() {
        if (jitsiApi) {
            jitsiApi.isVideoMuted().then(muted => {
                if (muted) {
                    jitsiApi.unmuteVideo();
                    this.classList.remove('btn-danger');
                    this.classList.add('btn-outline-secondary');
                    this.innerHTML = '<i class="bi bi-camera-video-fill"></i>';
                    showNotification('Camera turned on', 'success');
                } else {
                    jitsiApi.muteVideo();
                    this.classList.remove('btn-outline-secondary');
                    this.classList.add('btn-danger');
                    this.innerHTML = '<i class="bi bi-camera-video-off-fill"></i>';
                    showNotification('Camera turned off', 'info');
                }
            });
        }
    });
    
    // Screen share with visual feedback
    document.getElementById('toggle-screen').addEventListener('click', function() {
        if (jitsiApi) {
            jitsiApi.toggleShareScreen();
            this.classList.toggle('active');
            const isActive = this.classList.contains('active');
            showNotification(isActive ? 'Screen sharing started' : 'Screen sharing stopped', isActive ? 'success' : 'info');
        }
    });
    
    // End meeting (just close video, don't complete session)
    document.getElementById('end-meeting').addEventListener('click', function() {
        if (confirm('Are you sure you want to end the video call? You can start it again later.')) {
            endVideoCall();
        }
    });
    
    // End session (close video AND mark as completed)
    document.getElementById('end-session').addEventListener('click', function() {
        if (confirm('Are you sure you want to end the meeting and mark this session as completed? This action cannot be undone.')) {
            endMeetingAndCompleteSession();
        }
    });
    
    // Copy link with enhanced feedback
    document.getElementById('copy-meeting-link').addEventListener('click', function() {
        const meetingUrl = "{{ session.meetingUrl|default('') }}";
        if (meetingUrl) {
            navigator.clipboard.writeText(meetingUrl).then(() => {
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="bi bi-check me-1"></i>Copied!';
                this.classList.remove('btn-outline-primary');
                this.classList.add('btn-success');
                showNotification('Meeting link copied to clipboard!', 'success');
                
                setTimeout(() => {
                    this.innerHTML = originalText;
                    this.classList.remove('btn-success');
                    this.classList.add('btn-outline-primary');
                }, 2000);
            });
        }
    });
    
    // Fullscreen with enhanced feedback
    document.getElementById('fullscreen-meeting').addEventListener('click', function() {
        const meetingFrame = document.getElementById('jitsi-meeting-frame');
        if (!document.fullscreenElement) {
            meetingFrame.requestFullscreen();
            this.innerHTML = '<i class="bi bi-fullscreen-exit me-1"></i>Exit Fullscreen';
            showNotification('Entered fullscreen mode', 'info');
        } else {
            document.exitFullscreen();
            this.innerHTML = '<i class="bi bi-fullscreen me-1"></i>Fullscreen';
            showNotification('Exited fullscreen mode', 'info');
        }
    });
}

function updateMeetingControls() {
    // Update button states based on actual Jitsi API state
    if (jitsiApi && meetingActive) {
        jitsiApi.isAudioMuted().then(muted => {
            const audioBtn = document.getElementById('toggle-audio');
            if (muted) {
                audioBtn.classList.add('btn-danger');
                audioBtn.classList.remove('btn-outline-secondary');
                audioBtn.innerHTML = '<i class="bi bi-mic-mute-fill"></i>';
            }
        });
        
        jitsiApi.isVideoMuted().then(muted => {
            const videoBtn = document.getElementById('toggle-video');
            if (muted) {
                videoBtn.classList.add('btn-danger');
                videoBtn.classList.remove('btn-outline-secondary');
                videoBtn.innerHTML = '<i class="bi bi-camera-video-off-fill"></i>';
            }
        });
    }
}

function startMeeting() {
    const meetingUrl = "{{ session.meetingUrl|default('') }}";
    if (meetingUrl) {
        // Show loader
        document.getElementById('meeting-loader').style.display = 'block';
        
        document.getElementById('meeting-placeholder').style.display = 'none';
        document.getElementById('jitsi-meeting-container').style.display = 'block';
        
        // Add entrance animation
        const container = document.getElementById('jitsi-meeting-container');
        container.style.opacity = '0';
        container.style.transform = 'translateY(20px)';
        
        setTimeout(() => {
            container.style.transition = 'all 0.5s ease';
            container.style.opacity = '1';
            container.style.transform = 'translateY(0)';
        }, 100);
        
        initializeJitsi(meetingUrl);
    }
}

function endVideoCall() {
    if (jitsiApi) {
        jitsiApi.dispose();
        jitsiApi = null;
    }
    meetingActive = false;
    stopMeetingTimer();
    
    // Add exit animation
    const container = document.getElementById('jitsi-meeting-container');
    container.style.transition = 'all 0.3s ease';
    container.style.opacity = '0';
    container.style.transform = 'translateY(-20px)';
    
    setTimeout(() => {
        document.getElementById('jitsi-meeting-container').style.display = 'none';
        document.getElementById('meeting-placeholder').style.display = 'block';
        container.style.opacity = '1';
        container.style.transform = 'translateY(0)';
    }, 300);
    
    // Clear the iframe and show loader again
    const meetingFrame = document.getElementById('jitsi-meeting-frame');
    meetingFrame.innerHTML = '<div id="meeting-loader" class="position-absolute top-50 start-50 translate-middle text-white"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading meeting...</span></div></div>';
    
    updateMeetingStatus('ENDED', 'secondary');
    showNotification('Video call ended. You can start it again later.', 'info');
}

function endMeetingAndCompleteSession() {
    if (jitsiApi) {
        jitsiApi.dispose();
        jitsiApi = null;
    }
    meetingActive = false;
    stopMeetingTimer();
    
    document.getElementById('jitsi-meeting-container').style.display = 'none';
    document.getElementById('meeting-placeholder').style.display = 'block';
    
    // Clear the iframe
    const meetingFrame = document.getElementById('jitsi-meeting-frame');
    meetingFrame.innerHTML = '';
    
    // Mark session as completed
    markSessionCompleted();
}

function markSessionCompleted() {
    fetch('{{ path("app_coach_session_complete", {"id": session.id}) }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            console.log('Session marked as completed');
            updateMeetingStatus('COMPLETED', 'success');
            showNotification('Session completed successfully!', 'success');
        } else {
            console.error('Failed to mark session as completed:', data.error);
            showNotification('Failed to mark session as completed', 'error');
        }
    })
    .catch(error => {
        console.error('Error marking session as completed:', error);
        showNotification('Error updating session status', 'error');
    });
}

function showNotification(message, type) {
    // Remove any existing notifications
    const existingNotifications = document.querySelectorAll('.custom-notification');
    existingNotifications.forEach(n => n.remove());
    
    // Create a modern notification
    const notification = document.createElement('div');
    notification.className = `custom-notification alert alert-${type} position-fixed top-0 start-50 translate-middle-x mt-3 shadow-lg`;
    notification.style.zIndex = '9999';
    notification.style.minWidth = '300px';
    notification.style.animation = 'slideDown 0.3s ease';
    
    // Add icon based on type
    let icon = '';
    switch(type) {
        case 'success':
            icon = '<i class="bi bi-check-circle-fill me-2"></i>';
            break;
        case 'error':
            icon = '<i class="bi bi-x-circle-fill me-2"></i>';
            break;
        case 'info':
            icon = '<i class="bi bi-info-circle-fill me-2"></i>';
            break;
        default:
            icon = '<i class="bi bi-bell me-2"></i>';
    }
    
    notification.innerHTML = `${icon}${message}`;
    
    document.body.appendChild(notification);
    
    // Remove after 3 seconds with animation
    setTimeout(() => {
        notification.style.animation = 'slideUp 0.3s ease';
        setTimeout(() => {
            notification.remove();
        }, 300);
    }, 3000);
}

