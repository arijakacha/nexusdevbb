// Manual WhatsApp sending via Twilio API
document.getElementById('send-test-whatsapp')?.addEventListener('click', function() {
    console.log('WhatsApp button clicked!');
    
    const phoneNumber = document.getElementById('manual-phone').value.trim();
    console.log('Phone number entered:', phoneNumber);
    
    if (!phoneNumber) {
        showNotification('Please enter a phone number', 'warning');
        return;
    }
    
    // Basic phone number validation
    if (!phoneNumber.match(/^\+[1-9][0-9]{6,14}$/)) {
        showNotification('Please enter a valid phone number with country code (e.g., +1234567890)', 'warning');
        return;
    }
    
    const btn = this;
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Sending via Twilio...';
    console.log('Sending WhatsApp to:', phoneNumber);
    
    // Send via Twilio WhatsApp API
    fetch('{{ path("app_coach_session_send_whatsapp", {"id": session.id}) }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: 'phone_number=' + encodeURIComponent(phoneNumber)
    })
    .then(response => {
        console.log('Response status:', response.status);
        return response.json();
    })
    .then(data => {
        console.log('Response data:', data);
        if (data.success) {
            showNotification('WhatsApp message sent successfully to ' + phoneNumber + ' via Twilio!', 'success');
            // Clear the input after successful send
            document.getElementById('manual-phone').value = '';
        } else {
            showNotification('Failed to send WhatsApp: ' + data.error, 'error');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showNotification('An error occurred while sending WhatsApp message', 'error');
    })
    .finally(() => {
        btn.disabled = false;
        btn.innerHTML = originalText;
    });
});

