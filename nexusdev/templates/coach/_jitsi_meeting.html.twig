// Update createMeeting function to handle SMS status
function createMeeting() {
    const btn = document.getElementById('create-meeting-btn');
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Creating...';
    
    fetch('{{ path("app_coach_session_create_meeting", {"id": session.id}) }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Show SMS status
            let message = 'Meeting created successfully!';
            if (data.canReceiveSms) {
                if (data.smsSent) {
                    message += ' SMS sent to player.';
                } else if (data.smsError) {
                    message += ' SMS failed: ' + data.smsError;
                }
            }
            
            alert(message);
            window.location.reload();
        } else {
            alert('Failed to create meeting: ' + data.error);
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('An error occurred while creating the meeting');
        btn.disabled = false;
        btn.innerHTML = originalText;
    });
}
